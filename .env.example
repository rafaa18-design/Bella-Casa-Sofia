# Module Configuration
MODULE_ID=asani-agent-template
MODULE_VERSION=1.0.0
MODULE_DESCRIPTION=Asani AI Agent Template - AgentBench Standard

# Model Configuration
DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Agent Configuration
AGENT_PROMPT_NAME=agent-instructions
AGENT_INSTRUCTIONS_FALLBACK=You are a helpful AI assistant.
MAX_TURNS=10

# Langfuse Configuration (observability & prompt management)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
